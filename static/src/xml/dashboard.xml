<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="aq_meeting_rooms.Dashboard">
        <div class="o_aq_rooms">
            <div class="salas__backdrop" aria-hidden="true">
                <span class="salas__blob salas__blob--a"/>
                <span class="salas__blob salas__blob--b"/>
                <span class="salas__blob salas__blob--c"/>
            </div>

            <div class="salas__shell">

                <!-- Header -->
                <header class="salas__header">
                    <div class="salas__heading">
                        <span class="salas__eyebrow">
                            <span class="salas__dot" aria-hidden="true"/>
                            Operaciones · Espacios
                        </span>
                        <h1 class="salas__title">Salas de juntas</h1>
                        <p class="salas__lede">Consulta disponibilidad, elige una franja y crea solicitudes sujetas a autorización.</p>
                    </div>

                    <div class="salas__toolbar">
                        <div class="card card--inline date-picker">
                            <button class="date-picker__nav" type="button" data-day="-1" aria-label="Día anterior" t-on-click="changeDateBy">‹</button>
                            <div class="date-picker__field">
                                <span class="label-mono">Fecha</span>
                                <div class="date-picker__row">
                                    <input class="date-picker__input" type="date" t-att-value="state.date" t-on-change="onDateChange"/>
                                    <span class="date-picker__long" t-esc="dateLong"/>
                                </div>
                            </div>
                            <button class="date-picker__nav" type="button" data-day="1" aria-label="Día siguiente" t-on-click="changeDateBy">›</button>
                        </div>

                        <div class="salas__updated">
                            <span class="label-mono">Actualizado</span>
                            <span class="salas__updated-time" t-esc="state.lastUpdatedText"/>
                        </div>

                        <button class="btn btn--primary" type="button" t-on-click="refreshDashboard">
                            <span class="btn__dot" aria-hidden="true"/>
                            Actualizar
                        </button>
                    </div>
                </header>

                <!-- KPIs -->
                <section class="kpis">
                    <article class="card kpi kpi--neutral">
                        <header class="kpi__head">
                            <span class="label-mono">Salas</span>
                            <span class="kpi__pip" aria-hidden="true"/>
                        </header>
                        <div class="kpi__body">
                            <span class="kpi__value" t-esc="state.rooms.length"/>
                            <svg class="kpi__spark" width="44" height="14" viewBox="0 0 44 14" aria-hidden="true">
                                <path d="M2 8 L10 7 L18 9 L26 6 L34 7 L42 5"/>
                            </svg>
                        </div>
                    </article>

                    <article class="card kpi kpi--available">
                        <header class="kpi__head">
                            <span class="label-mono">Disponibles</span>
                            <span class="kpi__pip" aria-hidden="true"/>
                        </header>
                        <div class="kpi__body">
                            <span class="kpi__value" t-esc="freeRoomsCount"/>
                            <svg class="kpi__spark" width="44" height="14" viewBox="0 0 44 14" aria-hidden="true">
                                <path d="M2 10 L10 8 L18 6 L26 5 L34 4 L42 3"/>
                            </svg>
                        </div>
                    </article>

                    <article class="card kpi kpi--occupied">
                        <header class="kpi__head">
                            <span class="label-mono">Ocupadas</span>
                            <span class="kpi__pip" aria-hidden="true"/>
                        </header>
                        <div class="kpi__body">
                            <span class="kpi__value" t-esc="occupiedRoomsCount"/>
                            <svg class="kpi__spark" width="44" height="14" viewBox="0 0 44 14" aria-hidden="true">
                                <path d="M2 11 L10 11 L18 10 L26 10 L34 9 L42 9"/>
                            </svg>
                        </div>
                    </article>

                    <article class="card kpi kpi--pending">
                        <header class="kpi__head">
                            <span class="label-mono" t-if="state.canApprove">Pendientes</span>
                            <span class="label-mono" t-else="">Mis pendientes</span>
                            <span class="kpi__pip" aria-hidden="true"/>
                        </header>
                        <div class="kpi__body">
                            <span class="kpi__value" t-esc="state.pendingBookings.length"/>
                            <svg class="kpi__spark" width="44" height="14" viewBox="0 0 44 14" aria-hidden="true">
                                <path d="M2 11 L10 10 L18 10 L26 11 L34 10 L42 10"/>
                            </svg>
                        </div>
                    </article>
                </section>

                <t t-if="state.loading">
                    <div class="card loading-card">
                        <span class="loading-card__dot"/>
                        <span>Cargando disponibilidad…</span>
                    </div>
                </t>

                <t t-else="">
                    <div class="layout">

                        <!-- Salas -->
                        <aside class="card rooms">
                            <header class="rooms__head">
                                <h2 class="rooms__title">Salas</h2>
                                <span class="label-mono" t-esc="state.date"/>
                            </header>

                            <ul class="rooms__list" t-if="state.rooms.length">
                                <li t-foreach="state.rooms" t-as="room" t-key="room.id">
                                    <button type="button"
                                            t-att-data-room-id="room.id"
                                            t-on-click="selectRoom"
                                            t-att-class="'room ' + (state.selectedRoomId === room.id ? 'is-selected' : '')">
                                        <div class="room__top">
                                            <span t-att-class="'room__dot ' + roomDotClass(room)" aria-hidden="true"/>
                                            <div class="room__info">
                                                <span class="room__name" t-esc="room.name"/>
                                                <span class="room__meta">
                                                    <t t-esc="room.capacity || 0"/>p
                                                    <t t-if="room.location"> · <t t-esc="room.location"/></t>
                                                </span>
                                            </div>
                                            <span t-att-class="'pill ' + roomPillClass(room)" t-esc="roomStatusLabel(room)"/>
                                        </div>

                                        <div class="room__strip">
                                            <span t-foreach="roomStripSlots"
                                                  t-as="hour"
                                                  t-key="hour"
                                                  t-att-class="'room__tick ' + (roomHasBookingAt(room.id, hour) ? 'is-booked' : '')"/>
                                        </div>
                                    </button>
                                </li>
                            </ul>

                            <div class="empty empty--card" t-else="">
                                <strong>No hay salas registradas</strong>
                                <span class="empty__hint">Da de alta salas desde Configuración.</span>
                            </div>
                        </aside>

                        <!-- Agenda -->
                        <section class="card agenda">
                            <header class="agenda__head">
                                <div class="agenda__title-block">
                                    <span class="label-mono">Agenda · <span t-esc="dateShort"/></span>
                                    <h2 class="agenda__title" t-if="selectedRoom" t-esc="selectedRoom.name"/>
                                    <h2 class="agenda__title" t-else="">Selecciona una sala</h2>

                                    <div class="agenda__meta" t-if="selectedRoom">
                                        <t t-foreach="selectedRoomMetaParts" t-as="part" t-key="part_index">
                                            <span class="agenda__sep" t-if="part_index">·</span>
                                            <span t-esc="part"/>
                                        </t>
                                    </div>
                                </div>

                                <div class="seg">
                                    <button class="seg__btn is-active" type="button">Timeline</button>
                                    <button class="seg__btn" type="button" t-if="selectedRoom" t-on-click="openRoomCalendar">Calendario</button>
                                </div>
                            </header>

                            <div class="agenda__body">
                                <div class="empty" t-if="!selectedBookings.length">
                                    <span class="empty__icon" aria-hidden="true">✓</span>
                                    <strong>Sin reservas — </strong>
                                    <span class="empty__hint">da clic en una franja para preparar una solicitud.</span>
                                </div>

                                <div class="timeline">
                                    <div class="tl-row" t-foreach="timelineHours" t-as="hour" t-key="hour">
                                        <span class="tl-row__label" t-esc="formatHour(hour)"/>

                                        <div class="tl-row__slot" t-att-data-hour="hour" t-on-click="onTimelineSlotClick">
                                            <span class="tl-row__ghost">
                                                + Reservar <t t-esc="formatHour(hour)"/>
                                            </span>

                                            <article t-foreach="bookingsAtHour(hour)"
                                                     t-as="booking"
                                                     t-key="booking.id"
                                                     t-att-data-booking-id="booking.id"
                                                     t-att-class="'event ' + bookingStateClass(booking.state)"
                                                     t-att-style="timelineEventStyle(booking)"
                                                     t-on-click="openBooking">
                                                <div class="event__top">
                                                    <span class="event__title" t-esc="booking.objective"/>
                                                    <span class="event__time" t-esc="bookingRange(booking)"/>
                                                </div>
                                                <span class="event__owner" t-esc="booking.requested_by"/>
                                            </article>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>

                        <!-- Solicitud + pendientes -->
                        <div class="right-col">

                            <section class="card form">
                                <header class="form__head">
                                    <div>
                                        <span class="label-mono">Nueva solicitud</span>
                                        <h2 class="form__title">Reservar sala</h2>
                                    </div>

                                    <button type="button" class="btn btn--ghost btn--sm" t-on-click="openFullRequestForm">
                                        Completo
                                    </button>
                                </header>

                                <form class="form__body" t-on-submit.prevent="createQuickRequest">
                                    <label class="field">
                                        <span class="label-mono">Sala</span>
                                        <select class="input input--select" t-att-value="state.selectedRoomId || ''" t-on-change="onRoomSelect">
                                            <option value="">Selecciona…</option>
                                            <option t-foreach="state.rooms"
                                                    t-as="room"
                                                    t-key="room.id"
                                                    t-att-value="room.id"
                                                    t-att-selected="state.selectedRoomId === room.id">
                                                <t t-esc="room.name"/>
                                            </option>
                                        </select>
                                    </label>

                                    <div class="field-grid">
                                        <label class="field">
                                            <span class="label-mono">Inicio</span>
                                            <input class="input input--mono" type="datetime-local" t-model="state.form.start"/>
                                        </label>

                                        <label class="field">
                                            <span class="label-mono">Fin</span>
                                            <input class="input input--mono" type="datetime-local" t-model="state.form.stop"/>
                                        </label>
                                    </div>

                                    <label class="field">
                                        <span class="label-mono">Objetivo</span>
                                        <input class="input js-aq-objective"
                                               type="text"
                                               t-model="state.form.objective"
                                               placeholder="Ej. Revisión semanal"/>
                                    </label>

                                    <label class="field">
                                        <span class="field__label-row">
                                            <span class="label-mono">Agenda</span>
                                            <span class="field__hint">Opcional</span>
                                        </span>
                                        <textarea class="input input--textarea"
                                                  t-model="state.form.agenda"
                                                  rows="3"
                                                  placeholder="1. Avances&#10;2. Bloqueos&#10;3. Acuerdos esperados"/>
                                    </label>

                                    <p class="aq-alert" t-if="hasInvalidSlot">
                                        La hora de fin debe ser mayor que la de inicio.
                                    </p>

                                    <div class="aq-alert aq-alert-warn" t-if="quickConflicts.length">
                                        <strong>Horario ocupado</strong>
                                        <ul>
                                            <li t-foreach="quickConflicts" t-as="booking" t-key="booking.id">
                                                <t t-esc="bookingRange(booking)"/> · <t t-esc="booking.objective"/>
                                            </li>
                                        </ul>
                                    </div>

                                    <footer class="form__foot">
                                        <span class="hint">
                                            <span class="hint__i" aria-hidden="true">i</span>
                                            Sujeto a autorización
                                        </span>

                                        <button class="btn btn--primary"
                                                type="submit"
                                                t-att-disabled="!state.selectedRoomId || !hasObjective || hasInvalidSlot || quickConflicts.length">
                                            Enviar
                                            <span class="btn__kbd">↵</span>
                                        </button>
                                    </footer>
                                </form>
                            </section>

                            <section class="card pending">
                                <header class="pending__head">
                                    <div>
                                        <span class="label-mono" t-if="state.canApprove">Pendientes</span>
                                        <span class="label-mono" t-else="">Mis pendientes</span>
                                        <h2 class="pending__title">
                                            <span t-esc="state.pendingBookings.length"/>
                                            <span t-if="state.pendingBookings.length === 1"> solicitud</span>
                                            <span t-else=""> solicitudes</span>
                                        </h2>
                                    </div>

                                    <span class="pill pill--pending" t-if="state.pendingBookings.length">
                                        <t t-esc="state.pendingBookings.length"/> en revisión
                                    </span>
                                </header>

                                <div class="pending__body" t-if="state.pendingBookings.length">
                                    <article class="pending-item"
                                             t-foreach="state.pendingBookings"
                                             t-as="booking"
                                             t-key="booking.id">
                                        <header class="pending-item__head">
                                            <div class="pending-item__info">
                                                <span class="pending-item__title" t-esc="booking.objective"/>
                                                <span class="pending-item__meta">
                                                    <t t-esc="booking.room_name"/> · <t t-esc="bookingRange(booking)"/>
                                                </span>
                                            </div>
                                            <span t-att-class="'pill ' + bookingPillClass(booking.state)" t-esc="booking.state_label"/>
                                        </header>

                                        <footer class="pending-item__foot">
                                            <span class="pending-item__owner">
                                                <span class="avatar" t-esc="pendingInitials(booking)"/>
                                                <span class="pending-item__name" t-esc="booking.requested_by"/>
                                            </span>

                                            <div class="pending-item__actions">
                                                <button class="btn btn--ghost btn--sm"
                                                        type="button"
                                                        t-att-data-booking-id="booking.id"
                                                        t-on-click="openBooking">
                                                    Abrir
                                                </button>

                                                <button class="btn btn--primary btn--sm"
                                                        type="button"
                                                        t-if="state.canApprove"
                                                        t-att-data-booking-id="booking.id"
                                                        t-on-click="approveBooking">
                                                    Autorizar
                                                </button>

                                                <button class="btn btn--danger btn--sm"
                                                        type="button"
                                                        t-if="state.canApprove"
                                                        t-att-data-booking-id="booking.id"
                                                        t-on-click="rejectBooking">
                                                    Rechazar
                                                </button>
                                            </div>
                                        </footer>
                                    </article>
                                </div>

                                <div class="empty empty--card" t-else="">
                                    <strong>Sin solicitudes pendientes</strong>
                                    <span class="empty__hint">Cuando alguien envíe una reserva aparecerá aquí.</span>
                                </div>
                            </section>

                        </div>
                    </div>
                </t>

                <footer class="salas__foot">
                    <span>v0.6 · aq_meeting_rooms</span>
                    <span>Las solicitudes pasan por aprobación de Operaciones.</span>
                </footer>
            </div>
        </div>
    </t>
</templates>